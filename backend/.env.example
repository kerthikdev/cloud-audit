# ─── Cloud Audit Platform — Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Option A: MongoDB Atlas (recommended — cloud, no local install)
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# Option B: Local MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=cloudaudit

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-random-64-char-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=120

# ─── AWS ─────────────────────────────────────────────────────────────────────
MOCK_AWS=true
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# SCAN_REGIONS=us-east-1,us-west-2

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Alerting (optional) ──────────────────────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
